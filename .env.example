# LlamaFarm Environment Configuration
# Copy this file to .env and fill in your API keys

# ============================================================================
# API KEYS FOR CLOUD PROVIDERS
# ============================================================================

# OpenAI Configuration
OPENAI_API_KEY=  # Get from: https://platform.openai.com/api-keys
OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_ORG_ID=  # Optional: your organization ID (commented out to prevent header issues)

# Anthropic Configuration (Claude)
ANTHROPIC_API_KEY=  # Get from: https://console.anthropic.com/
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Together.ai Configuration
TOGETHER_API_KEY=  # Get from: https://api.together.xyz/signin
TOGETHER_BASE_URL=https://api.together.xyz/v1

# Groq Configuration (Ultra-fast inference)
GROQ_API_KEY=  # Get from: https://console.groq.com/
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Cohere Configuration
COHERE_API_KEY=  # Get from: https://dashboard.cohere.ai/
COHERE_BASE_URL=https://api.cohere.ai/v1

# ============================================================================
# LOCAL MODEL PROVIDERS
# ============================================================================

# Ollama Configuration (Local models)
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://localhost:11434

# vLLM Configuration (High-throughput local inference)
VLLM_HOST=localhost
VLLM_PORT=8000
VLLM_BASE_URL=http://localhost:8000

# Text Generation Inference (TGI)
TGI_HOST=localhost
TGI_PORT=8080
TGI_BASE_URL=http://localhost:8080

# Hugging Face Token (Optional)
HF_TOKEN=  # Get from: https://huggingface.co/settings/tokens

# ============================================================================
# MODEL PREFERENCES
# ============================================================================

# Preferred OpenAI model to use
OPENAI_MODEL=gpt-4o-mini

# ============================================================================
# SYSTEM CONFIGURATION
# ============================================================================

# Environment (development, staging, production)
ENVIRONMENT=development

# Debug mode
DEBUG=false

# Logging level
LOG_LEVEL=INFO

# ============================================================================
# EDGE RUNTIME CONFIGURATION
# ============================================================================

# Comma-separated list of GGUF models to preload at startup (eliminates cold-start)
PRELOAD_MODELS=

# Context size for preloaded models (leave empty for auto-detection)
PRELOAD_N_CTX=

# Directory containing local GGUF model files
GGUF_MODELS_DIR=

# ============================================================================
# OFFLINE / AIR-GAPPED DEPLOYMENT
# ============================================================================

# Strict offline mode. When set to "1", the runtime refuses all outbound
# network requests for model and llama.cpp binary resolution, raising a
# clear error that points at the `lf` CLI command that would make the
# missing file available. Also propagates HF_HUB_OFFLINE=1 and
# TRANSFORMERS_OFFLINE=1 so huggingface_hub / transformers honor it.
# Used by llamadrone / arc air-gapped deployments.
# LLAMAFARM_OFFLINE=1

# Flat-directory model layout root. When set, the runtime looks for
# models under $LLAMAFARM_MODEL_DIR/<alias>/ before falling back to the
# HuggingFace cache. `<alias>` is the model's name from runtime.models[]
# in llamafarm.yaml. Files are discovered by format sniffing so both
# canonical (`model.Q4_K_M.gguf`) and HF-preserved
# (`Qwen3-1.7B-Q4_K_M.gguf`) filenames work.
# Complements GGUF_MODELS_DIR above: GGUF_MODELS_DIR is a flat file
# layout used by the edge runtime's local-file resolution; this one
# uses a per-alias subdirectory layout emitted by `lf models path`.
# LLAMAFARM_MODEL_DIR=/opt/llamafarm/models
